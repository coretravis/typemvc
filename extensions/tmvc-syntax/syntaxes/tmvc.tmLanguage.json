{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TypeMVC",
  "scopeName": "text.html.tmvc",
  "fileTypes": [
    "tmvc"
  ],
  "patterns": [
    {
      "include": "#parent-directive"
    },
    {
      "include": "#local-block"
    },
    {
      "include": "#interpolation"
    },
    {
      "include": "text.html.basic"
    }
  ],
  "repository": {
    "parent-directive": {
      "match": "^[ \\t]*(@parent)[ \\t]+([A-Za-z_$][\\w$-]*)[ \\t]*$",
      "captures": {
        "1": {
          "name": "keyword.control.parent.tmvc"
        },
        "2": {
          "name": "entity.name.type.layout.tmvc"
        }
      }
    },
    "local-block": {
      "name": "meta.local.tmvc",
      "begin": "^\\s*(@local)\\s*(\\{)",
      "end": "(\\})",
      "applyEndPatternLast": 1,
      "beginCaptures": {
        "1": {
          "name": "keyword.control.local.tmvc"
        },
        "2": {
          "name": "punctuation.section.block.begin.bracket.curly.ts"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.section.block.end.bracket.curly.ts"
        }
      },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        {
          "include": "#nested-braces"
        },
        {
          "include": "source.ts"
        }
      ]
    },
    "interpolation": {
      "name": "meta.template.expression.tmvc",
      "begin": "(\\$\\{)",
      "end": "(\\})",
      "applyEndPatternLast": 1,
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.template-expression.begin.tmvc"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.template-expression.end.tmvc"
        }
      },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        {
          "include": "#nested-braces"
        },
        {
          "include": "source.ts"
        }
      ]
    },
    "nested-braces": {
      "name": "meta.block.ts",
      "begin": "(\\{)",
      "end": "(\\})",
      "applyEndPatternLast": 1,
      "beginCaptures": {
        "1": {
          "name": "punctuation.section.block.begin.bracket.curly.ts"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.section.block.end.bracket.curly.ts"
        }
      },
      "patterns": [
        {
          "include": "#nested-braces"
        },
        {
          "include": "source.ts"
        }
      ]
    }
  }
}
